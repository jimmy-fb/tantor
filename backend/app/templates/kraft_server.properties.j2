# Tantor-generated KRaft Kafka Server Configuration
# Role: {{ process_roles }}

node.id={{ node_id }}
process.roles={{ process_roles }}

controller.quorum.voters={{ quorum_voters }}

listeners={{ listeners }}
advertised.listeners={{ advertised_listeners }}
controller.listener.names=CONTROLLER
inter.broker.listener.name=PLAINTEXT
listener.security.protocol.map=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT

log.dirs={{ log_dirs }}

num.network.threads=3
num.io.threads=8
socket.send.buffer.bytes=102400
socket.receive.buffer.bytes=102400
socket.request.max.bytes=104857600

num.partitions={{ num_partitions }}
default.replication.factor={{ replication_factor }}
min.insync.replicas={{ [replication_factor - 1, 1] | max }}

offsets.topic.replication.factor={{ replication_factor }}
transaction.state.log.replication.factor={{ replication_factor }}
transaction.state.log.min.isr={{ [replication_factor - 1, 1] | max }}

log.retention.hours=168
log.segment.bytes=1073741824
log.retention.check.interval.ms=300000

group.initial.rebalance.delay.ms=0

# Security: ACL authorizer (KRaft native)
authorizer.class.name=org.apache.kafka.metadata.authorizer.StandardAuthorizer
super.users=User:ANONYMOUS
allow.everyone.if.no.acl.found=true
