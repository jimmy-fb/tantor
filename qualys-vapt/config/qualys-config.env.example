###############################################################################
# Qualys Community Edition Configuration
# ----------------------------------------
# Copy this file to qualys-config.env and fill in your credentials
#
# Sign up at: https://www.qualys.com/community-edition/
# API docs:   https://www.qualys.com/docs/qualys-api-vmpc-user-guide.pdf
###############################################################################

# ── Qualys API Credentials ────────────────────────────────────────────────
# Platform URL depends on your assigned Qualys platform
# US Platform 1: https://qualysapi.qualys.com
# US Platform 2: https://qualysapi.qg2.apps.qualys.com
# EU Platform:   https://qualysapi.qualys.eu
# India:         https://qualysapi.qg1.apps.qualys.in
QUALYS_API_URL=https://qualysapi.qualys.com

# Your Qualys username and password
QUALYS_USERNAME=your_username_here
QUALYS_PASSWORD=your_password_here

# ── Virtual Scanner Configuration ─────────────────────────────────────────
# Personalization code from Qualys portal (Scans > Appliances > New > Virtual Scanner)
QUALYS_PERSO_CODE=XXXX-XXXX-XXXX-XXXX-XXXX

# Scanner name (as it appears in Qualys portal)
QUALYS_SCANNER_NAME=kafka-vapt-scanner

# ── Scan Configuration ────────────────────────────────────────────────────
# Target IPs/ranges for Kafka brokers (Docker network)
QUALYS_SCAN_TARGETS=172.28.0.10-172.28.0.12,172.28.0.20

# Scan title prefix
QUALYS_SCAN_TITLE=Kafka-VAPT-Scan

# Option Profile ID (create one in Qualys portal or use default)
# To use the default "Initial Options" profile, leave empty
QUALYS_OPTION_PROFILE_ID=

# ── Report Configuration ──────────────────────────────────────────────────
# Report template ID (from Qualys portal > Reports > Templates)
QUALYS_REPORT_TEMPLATE_ID=

# Report format: PDF, HTML, CSV, XML
QUALYS_REPORT_FORMAT=PDF
